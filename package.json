{
  "name": "roguelike-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck",
    "build": "tsc && vite build",
    "preview": "vite preview",
